{
  "name": "sydes",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "sim": "tsx src/engine/cli.ts",
    "agent:dev": "tsx watch src/agent/main.ts",
    "agent:start": "tsx src/agent/main.ts",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "dev": "concurrently -n agent,web \"npm run agent:dev\" \"npm run web:dev\""
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "concurrently": "^10.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "dockerode": "^5.0.0",
    "fastify": "^5.8.5"
  }
}
